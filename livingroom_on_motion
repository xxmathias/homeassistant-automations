alias: livingroom_on_motion
description: Motion-activated lighting with adaptive brightness and color
triggers:
  - type: occupied
    device_id: b1b329d4ce5d2ab76da71acd1fc3c4a2
    entity_id: edba6ca93c009b956f6a4c0576bb40cf
    domain: binary_sensor
    trigger: device
conditions:
  - condition: numeric_state
    entity_id: sensor.sun_solar_elevation
    below: 30
  - condition: state
    entity_id: light.wohnzimmerlampe
    state: "off"
  - condition: time
    after: "10:00:00"
    before: "23:00:00"
actions:
  # Get adaptive brightness
  - service: script.adaptive_brightness
    data:
      mode: normal
      room: wohnzimmer
    response_variable: brightness_result
  # Get adaptive color temperature
  - service: script.adaptive_color_temp
    data:
      force_warm: false
    response_variable: color_result
  # Turn on living room lights
  - service: light.turn_on
    target:
      area_id: wohnzimmer
    data:
      transition: 2
      brightness_pct: "{{ brightness_result.brightness }}"
      kelvin: "{{ color_result.kelvin }}"
mode: restart
